[flake8]
max-line-length = 120
ignore =
    # W503: line break before binary operator (conflicts with W504)
    # W504: line break after binary operator (style choice)
    W503,
    W504,
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info
per-file-ignores =
    tests/test_conversation.py:E402,
    tests/test_config_flow.py:E402,
    tests/test_services.py:E402
